{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travelbrain-data.example/schemas/corridor.schema.json",
  "title": "TravelBrain corridor source",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "status", "originCountry", "destination", "travelModes", "options"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "status": { "enum": ["draft", "approved", "blocked"] },
    "originCountry": { "type": "string", "pattern": "^[A-Z]{2}$" },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["country"],
      "properties": {
        "country": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "regionTags": { "type": "array", "uniqueItems": true, "items": { "type": "string" } }
      }
    },
    "travelModes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["car", "motorcycle", "motorhome"] }
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "countries", "recommended", "notes"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "label": {
            "type": "object",
            "required": ["de"],
            "additionalProperties": false,
            "properties": { "de": { "type": "string", "minLength": 1 } }
          },
          "countries": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string", "pattern": "^[A-Z]{2}$" }
          },
          "recommended": { "type": "boolean" },
          "notes": {
            "type": "object",
            "required": ["de"],
            "additionalProperties": false,
            "properties": { "de": { "type": "string", "minLength": 1 } }
          }
        }
      }
    }
  }
}
