{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travelbrain-data.example/schemas/manifest.schema.json",
  "title": "TravelBrain distribution manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "contentVersion", "generatedAt", "minimumAppSchemaVersion", "countries", "corridorsVersion"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "contentVersion": { "type": "string", "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}\\.[0-9]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "minimumAppSchemaVersion": { "type": "integer", "minimum": 1 },
    "countries": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["coverage", "version", "sha256", "path"],
        "properties": {
          "coverage": { "enum": ["complete", "partial"] },
          "version": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "path": { "type": "string", "pattern": "^countries/[a-z]{2}\\.json$" }
        }
      }
    },
    "corridorsVersion": { "type": "string" }
  }
}
